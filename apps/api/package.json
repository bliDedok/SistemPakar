{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main/index.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ./prisma/schema.prisma",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema ./prisma/schema.prisma --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "pnpm run db:migrate && pnpm run db:seed",
    "db:fresh": "pnpm run db:reset && pnpm run db:seed"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fastify": "^5.0.0",
    "pg": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.0.0",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
