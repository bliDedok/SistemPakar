generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RuleOperator {
  AND
  OR
}

enum Gender {
  MALE
  FEMALE
}

enum SymptomItemType {
  SYMPTOM
  WARNING
  SEVERITY
  CONTEXT
  LAB
  COMPLICATION
}

enum InputTier {
  CAREGIVER
  CAREGIVER_OR_CLINICIAN
  CLINICIAN
  CLINICIAN_OR_CAREGIVER
  HISTORY_CONTEXT
  LAB
  LAB_OR_CLINICIAN
}

enum SymptomRole {
  CORE
  SUPPORTING
  WARNING_SIGN
  SEVERE
  CONTEXT_ONLY
  COMPLICATION
}

enum KeepStatus {
  KEEP
  KEEP_OPTIONAL
  EXCLUDE
}

enum UrgencyMode {
  ORDINARY
  URGENCY_ONLY
}

model EvidenceChunk {
  id          String   @id @default(cuid())

  diseaseId   String?
  symptomId   String?

  title       String
  content     String
  sourceName  String?
  sourceType  String   @default("curated_reference")
  sourceUrl   String?
  evidenceDoi String?

  embedding   Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  disease     Disease? @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  symptom     Symptom? @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@index([diseaseId])
  @@index([symptomId])
}

model Disease {
  id            String                 @id @default(cuid())
  code          String                 @unique
  name          String
  description   String?
  advice        String?
  severityLevel String?
  sourceUrl     String?
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  rules         Rule[]
  weights       DiseaseSymptomWeight[]
  results       ConsultationResult[]
  evidenceChunks EvidenceChunk[]
}

model Symptom {
  id               String                 @id @default(cuid())
  code             String                 @unique
  name             String
  normalizedName   String?
  questionText     String
  category         String?
  itemType         SymptomItemType        @default(SYMPTOM)
  defaultInputTier InputTier?
  isRedFlag        Boolean                @default(false)
  isAskable        Boolean                @default(true)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  aliases          SymptomAlias[]
  ruleDetails      RuleDetail[]
  weights          DiseaseSymptomWeight[]
  answers          ConsultationAnswer[]
  evidenceChunks   EvidenceChunk[]

  @@index([normalizedName])
}

model SymptomAlias {
  id              String   @id @default(cuid())
  symptomId       String
  aliasText       String   @unique
  normalizedAlias String?
  createdAt       DateTime @default(now())

  symptom         Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@index([normalizedAlias])
}

model Rule {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  diseaseId String
  operator  RuleOperator @default(AND)
  minMatch  Int          @default(1)
  priority  Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  disease   Disease      @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  details   RuleDetail[]
}

model RuleDetail {
  id          String   @id @default(cuid())
  ruleId      String
  symptomId   String
  isMandatory Boolean  @default(false)

  rule        Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  symptom     Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@unique([ruleId, symptomId])
}

model DiseaseSymptomWeight {
  id             String       @id @default(cuid())
  diseaseId      String
  symptomId      String
  cfExpert       Float
  candidateCfMin Float?
  candidateCfMax Float?
  symptomRole    SymptomRole  @default(SUPPORTING)
  phase          String?
  keepStatus     KeepStatus   @default(KEEP)
  urgencyMode    UrgencyMode  @default(ORDINARY)
  evidenceDoi    String?
  note           String?

  disease        Disease      @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  symptom        Symptom      @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@unique([diseaseId, symptomId])
}


model Consultation {
  id             String               @id @default(cuid())
  childName      String?
  childAgeMonths Int
  gender         Gender?
  createdAt      DateTime             @default(now())

  answers        ConsultationAnswer[]
  results        ConsultationResult[]
}

model ConsultationAnswer {
  id             String        @id @default(cuid())
  consultationId String
  symptomId      String
  userCf         Float

  consultation   Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  symptom        Symptom       @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@unique([consultationId, symptomId])
}

model ConsultationResult {
  id             String        @id @default(cuid())
  consultationId String
  diseaseId      String
  matchCount     Int
  cfResult       Float
  rank           Int

  consultation   Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  disease        Disease       @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@unique([consultationId, diseaseId])
}
