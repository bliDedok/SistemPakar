generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RuleOperator {
  AND
  OR
}

enum Gender {
  MALE
  FEMALE
}

model Disease {
  id            String                 @id @default(cuid())
  code          String                 @unique
  name          String
  description   String?
  advice        String?
  severityLevel String?
  sourceUrl     String?
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  rules         Rule[]
  weights       DiseaseSymptomWeight[]
  results       ConsultationResult[]
}

model Symptom {
  id           String                 @id @default(cuid())
  code         String                 @unique
  name         String
  questionText String
  category     String?
  isRedFlag    Boolean                @default(false)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  ruleDetails  RuleDetail[]
  weights      DiseaseSymptomWeight[]
  answers      ConsultationAnswer[]
}

model Rule {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  diseaseId String
  operator  RuleOperator @default(AND)
  minMatch  Int          @default(1)
  priority  Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  disease   Disease      @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  details   RuleDetail[]
}

model RuleDetail {
  id          String   @id @default(cuid())
  ruleId      String
  symptomId   String
  isMandatory Boolean  @default(false)

  rule        Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  symptom     Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@unique([ruleId, symptomId])
}

model DiseaseSymptomWeight {
  id        String   @id @default(cuid())
  diseaseId String
  symptomId String
  cfExpert  Float
  note      String?

  disease   Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  symptom   Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@unique([diseaseId, symptomId])
}

model Consultation {
  id             String               @id @default(cuid())
  childName      String?
  childAgeMonths Int
  gender         Gender?
  createdAt      DateTime             @default(now())

  answers        ConsultationAnswer[]
  results        ConsultationResult[]
}

model ConsultationAnswer {
  id             String        @id @default(cuid())
  consultationId String
  symptomId      String
  userCf         Float

  consultation   Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  symptom        Symptom       @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@unique([consultationId, symptomId])
}

model ConsultationResult {
  id             String        @id @default(cuid())
  consultationId String
  diseaseId      String
  matchCount     Int
  cfResult       Float
  rank           Int

  consultation   Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  disease        Disease       @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@unique([consultationId, diseaseId])
}