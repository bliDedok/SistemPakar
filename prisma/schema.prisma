generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Symptom {
  id             String                 @id @default(cuid())
  code           String                 @unique
  name           String
  description    String?
  questionText   String?
  isRedFlag      Boolean                @default(false)
  ruleConditions RuleCondition[]
  diseaseWeights DiseaseSymptomWeight[]
  answers        ConsultationAnswer[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model Disease {
  id             String                 @id @default(cuid())
  code           String                 @unique
  name           String
  description    String?
  recommendation String?
  severityLevel  String?
  rules          Rule[]
  weights        DiseaseSymptomWeight[]
  results        DiagnosisResult[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model Rule {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  diseaseId       String
  operatorDefault String          @default("AND")
  minMatchCount   Int?
  disease         Disease         @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  conditions      RuleCondition[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model RuleCondition {
  id        String   @id @default(cuid())
  ruleId    String
  symptomId String
  operator  String?  @default("AND")
  weight    Float?
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  symptom   Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ruleId, symptomId])
}

model DiseaseSymptomWeight {
  id        String   @id @default(cuid())
  diseaseId String
  symptomId String
  mb        Float?
  md        Float?
  cfExpert  Float
  disease   Disease  @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  symptom   Symptom  @relation(fields: [symptomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([diseaseId, symptomId])
}

model Consultation {
  id           String                @id @default(cuid())
  userId       String?
  sessionTitle String?
  status       String                @default("draft")
  source       String                @default("chatbot")
  messages     ConsultationMessage[]
  answers      ConsultationAnswer[]
  results      DiagnosisResult[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model ConsultationMessage {
  id             String        @id @default(cuid())
  consultationId String
  role           String
  content        String
  consultation   Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
}

model ConsultationAnswer {
  id             String        @id @default(cuid())
  consultationId String
  symptomId      String
  confidenceUser Float
  durationDays   Int?
  notes          String?
  consultation   Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  symptom        Symptom       @relation(fields: [symptomId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
}

model DiagnosisResult {
  id              String        @id @default(cuid())
  consultationId  String
  diseaseId       String
  scoreCf         Float
  isPrimary       Boolean       @default(false)
  explanationJson Json?
  consultation    Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  disease         Disease       @relation(fields: [diseaseId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}